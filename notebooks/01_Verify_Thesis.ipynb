   "source": [
    "# Master\'s Thesis Verification\n\nThis notebook provides a step-by-step verification of the key details of the Master\'s thesis, \"Data Modeling in a Cross-domain Ontology for Cyber Intelligence in Smart-Grids Using Reinforcement Learning\", by Vincenzo Grimaldi."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n\n# Load the key details from the CSV file\nkey_details_df = pd.read_csv(\"../data/key_details.csv\")\n\n# Display the key details\nkey_details_df"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Thesis Details"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "thesis_title = key_details_df[key_details_df[\'detail_key\'] == \'Title\'][\'detail_value\'].iloc[0]\nauthor_name = key_details_df[key_details_df[\'detail_key\'] == \'Name\'][\'detail_value\'].iloc[0]\nsupervisor_name = key_details_df[key_details_df[\'detail_key\'] == \'Supervisor\'][\'detail_value\'].iloc[0]\nexaminer_name = key_details_df[key_details_df[\'detail_key\'] == \'Examiner\'][\'detail_value\'].iloc[0]\n\nprint(f\"Thesis Title: {thesis_title}\")\nprint(f\"Author: {author_name}\")\nprint(f\"Supervisor: {supervisor_name}\")\nprint(f\"Examiner: {examiner_name}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Keywords"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "keywords = key_details_df[key_details_df[\'section\'] == \'Keywords\'][\'detail_value\'].tolist()\n\nprint(\"Keywords:\")\nfor keyword in keywords:\n    print(f\"- {keyword}\")"
   ]
  }
 ],
